# ── Anthropic API key (required by agent_server.py) ──────────────────────────
# Set this in Railway's environment variables for the agent server service.
# Do NOT commit the real key — keep it in .env (git-ignored) locally.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Frontend: deployed backend URLs (set these in Vercel's environment vars) ──
# After deploying both Railway services, paste their public URLs here.
# These are VITE_ prefixed so they get embedded in the frontend build.

# Agent server Railway URL (HTTP/SSE — no trailing slash)
# Example: https://agentic-pollination-uav-agent.up.railway.app
VITE_AGENT_API_URL=https://your-agent-service.up.railway.app

# Inference server Railway URL (WebSocket — use wss:// for Railway HTTPS)
# Example: wss://agentic-pollination-uav-inference.up.railway.app/inference
VITE_INFERENCE_WS_URL=wss://your-inference-service.up.railway.app/inference
